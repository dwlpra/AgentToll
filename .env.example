# ── Gateway (Go) ──
# Provider wallet: can be overridden dynamically via MetaMask login in UI
GATEWAY_WALLET=0xYOUR_WALLET_ADDRESS
GATEWAY_SECRET=your-gateway-secret
GATEWAY_WEBHOOK_SECRET=your-webhook-hmac-secret
MOCK_API_URL=http://localhost:18091

# USDC on Base Mainnet
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Network: "base" (mainnet) or "base-sepolia" (testnet)
NETWORK=base
LISTEN_ADDR=:19090

# ── Agent (TypeScript) ──
GATEWAY_URL=http://localhost:19090
VENICE_API_KEY=your-venice-api-key
VENICE_MODEL=z-ai-glm-5-turbo
RPC_URL=https://mainnet.base.org

# Agent wallet: can be overridden dynamically via MetaMask login in UI
AGENT_WALLET=0xYOUR_WALLET_ADDRESS
PROVIDER_WALLET=0xYOUR_PROVIDER_WALLET

# Payment mode: "live" (autonomous on-chain via 1Shot relayer)
PAYMENT_MODE=live
BUDGET_USD=1.00

# Chain: 8453 = Base Mainnet (default), 84532 = Base Sepolia (testnet)
CHAIN_ID=8453
RELAYER_URL=https://relayer.1shotapi.com/relayers
EXPLORER_URL=https://basescan.org

# ── React UI (Vite) ──
VITE_GATEWAY_URL=http://localhost:19090
# Note: GATEWAY_SECRET is used server-side by Vite proxy (not exposed to browser)
# Set GATEWAY_SECRET env var before running the UI
