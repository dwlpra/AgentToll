# ═══════════════════════════════════════════════════════════
# PayCrawl — Mainnet Configuration (Base)
# ═══════════════════════════════════════════════════════════
# Copy ke agent/.env untuk mainnet deployment:
#   cp .env.mainnet .env

# ── Chain ──────────────────────────────────────────────────
# 8453 = Base Mainnet
# 84532 = Base Sepolia (testnet, default)
CHAIN_ID=8453
RPC_URL=https://mainnet.base.org
EXPLORER_URL=https://basescan.org

# ── Payment Mode ───────────────────────────────────────────
# "live" = otonom via 1Shot relayer (MAINNET)
# "bridge" = manual approve via browser
# "stub" = tanpa blockchain (testing only)
PAYMENT_MODE=live

# ── 1Shot Relayer ──────────────────────────────────────────
# .com = mainnet / .dev = testnet
RELAYER_URL=https://relayer.1shotapi.com/relayers

# ── Wallets ────────────────────────────────────────────────
# Agent wallet (yang membayar USDC) — harus punya USDC di Base
AGENT_WALLET=0xYOUR_AGENT_WALLET_ADDRESS

# Provider wallet (yang MENERIMA pembayaran) — wallet kamu
PROVIDER_WALLET=0xYOUR_PROVIDER_WALLET_ADDRESS

# ── Venice AI ──────────────────────────────────────────────
VENICE_API_KEY=YOUR_VENICE_API_KEY
VENICE_MODEL=zai-org-glm-5

# ── Gateway ────────────────────────────────────────────────
# URL gateway yang bisa diakses dari server
# Untuk server deploy, ganti localhost ke IP/domain server
GATEWAY_URL=http://localhost:19090
